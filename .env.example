# Flask
FLASK_ENV=production
DEBUG=0

# Flask secret
SECRET_KEY=change-me

# JWT
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400

# Criptografia (usado no projeto)
ENCRYPTION_KEY=change-me-32chars-minimum

# Database
# Use no Railway (ex: sqlite file or persistent volume).
# Se estiver usando SQLite local, o padrão do projeto usa database.db no repo.
DATABASE_URL=sqlite:///database.db

